// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum LeadStatus {
  NEW
  QUALIFIED
  DISCARDED
  CONTACTED
  CONVERTED
}

// ==========================================
// MODELS
// ==========================================

model Workspace {
  id                      String                    @id @default(cuid())
  name                    String
  slug                    String                    @unique
  plan                    String                    @default("FREE")
  status                  String                    @default("PENDING_REVIEW")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  ownerId                 String?

  // Relations
  users                   User[]
  businessProfile         BusinessProfile?
  gmailIntegration        GmailIntegration?
  whatsappIntegration     WhatsAppIntegration?
  googleSheetsIntegration GoogleSheetsIntegration?
  vapiIntegration         VapiIntegration?
  aiConfiguration         AIConfiguration?
  emailSignature          EmailSignature?
  companyKnowledge        CompanyKnowledge?
  leads                   Lead[]
  emails                  Email[]
  workflows               Workflow[]
  activityFeeds           ActivityFeed[]
  reports                 Report[]
  notifications           Notification[]
  calls                   Call[]
  whatsAppMessages        WhatsAppMessage[]
  customerMemories        CustomerMemory[]
  conversations           Conversation[]
  threads                 Thread[]

  @@index([slug])
  @@index([status])
}

model User {
  id            String     @id @default(cuid())
  firebaseUid   String     @unique
  name          String?
  email         String     @unique
  role          Role       @default(MEMBER)
  avatar        String?
  workspaceId   String?
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  auditLogs     AuditLog[]

  @@index([workspaceId])
  @@index([firebaseUid])
}

model BusinessProfile {
  id           String    @id @default(cuid())
  businessName String
  website      String?
  industry     String?
  phone        String?
  address      String?
  timezone     String    @default("UTC")
  logo         String?
  workspaceId  String    @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model GmailIntegration {
  id           String    @id @default(cuid())
  workspaceId  String    @unique
  email        String
  accessToken  String
  refreshToken String
  status       String    @default("CONNECTED")
  lastSyncAt   DateTime?
  connectedAt  DateTime  @default(now())
  tokenExpiry           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Auto-Reply Settings
  autoReplyEnabled      Boolean   @default(false)
  autoReplyTone         String    @default("Professional")
  autoReplyInstructions String?
  autoReplyHours        String?
  autoReplyDelay        Int       @default(5)
  autoReplySignature    String?

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WhatsAppIntegration {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  phoneNumber String?
  accessToken String?
  status      String    @default("CONNECTED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model GoogleSheetsIntegration {
  id            String    @id @default(cuid())
  workspaceId   String    @unique
  spreadsheetId String?
  sheetName     String?
  status        String    @default("CONNECTED")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model VapiIntegration {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  apiKey      String?
  assistantId String?
  status      String    @default("CONNECTED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AIConfiguration {
  id           String    @id @default(cuid())
  workspaceId  String    @unique
  modelName    String    @default("gemini-1.5-pro")
  temperature  Float     @default(0.7)
  systemPrompt String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Lead {
  id               String          @id @default(cuid())
  workspaceId      String
  name             String
  email            String
  phone            String?
  source           String?
  leadScore        Int             @default(0)
  priority         String          @default("MEDIUM")
  status           LeadStatus      @default(NEW)
  estimatedRevenue Float           @default(0.0)
  intent           String?
  notes            String?
  customerMemoryId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  emails           Email[]
  calls            Call[]
  aiReplies        AIReply[]
  customerMemory   CustomerMemory? @relation(fields: [customerMemoryId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([email])
  @@index([status])
  @@index([leadScore])
  @@index([customerMemoryId])
}

model Email {
  id               String          @id @default(cuid())
  workspaceId      String
  leadId           String?
  gmailMessageId   String?
  subject          String?
  sender           String
  recipient        String
  body             String?
  snippet          String?
  receivedAt       DateTime        @default(now())
  isRead           Boolean         @default(false)
  isArchived       Boolean         @default(false)
  status           String          @default("RECEIVED")
  leadScore        Int             @default(0)
  priority         String?
  intent           String?
  sentiment        String?
  aiSummary        String?
  customerMemoryId String?
  threadId         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead             Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  aiReplies        AIReply[]
  attachments      Attachment[]
  customerMemory   CustomerMemory? @relation(fields: [customerMemoryId], references: [id], onDelete: SetNull)
  thread           Thread?         @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([gmailMessageId])
  @@index([isRead])
  @@index([leadScore])
  @@index([customerMemoryId])
  @@index([threadId])
}

model AIReply {
  id             String    @id @default(cuid())
  emailId        String?
  leadId         String?
  generatedReply String
  editedReply    String?
  sentAt           DateTime?
  status           String    @default("DRAFT")
  model            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Upgraded fields
  recipient        String?
  subject          String?
  threadId         String?
  tone             String?
  confidence       Float?    @default(0.85)
  revenuePotential Float?    @default(0.0)
  responseReceived Boolean   @default(false)

  // Relations
  email            Email?    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([leadId])
}

model Call {
  id            String    @id @default(cuid())
  workspaceId   String
  leadId        String?
  phone         String
  duration      Int?
  status        String
  transcript    String?
  summary       String?
  recordingUrl  String?
  bookedMeeting Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead          Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
}

model WhatsAppMessage {
  id          String    @id @default(cuid())
  workspaceId String
  phone       String
  message     String
  direction   String
  aiResponse  String?
  status      String    @default("SENT")
  createdAt   DateTime  @default(now())

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([phone])
}

model Workflow {
  id          String              @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      String              @default("ACTIVE")
  trigger     String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions  WorkflowExecution[]

  @@index([workspaceId])
}

model WorkflowExecution {
  id            String   @id @default(cuid())
  workflowId    String
  status        String
  executionTime Int?
  payload       String?
  result        String?
  createdAt     DateTime @default(now())

  // Relations
  workflow      Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model ActivityFeed {
  id          String    @id @default(cuid())
  workspaceId String
  type        String
  title       String
  description String?
  metadata    String?
  createdAt   DateTime  @default(now())

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
}

model Report {
  id          String    @id @default(cuid())
  workspaceId String
  type        String
  period      String
  jsonData    String?
  generatedAt DateTime  @default(now())

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  message     String
  read        Boolean   @default(false)
  type        String
  createdAt   DateTime  @default(now())

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([read])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([timestamp])
}

model EmailSignature {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  name        String?
  designation String?
  company     String?
  phone       String?
  website     String?
  logoUrl     String?
  customHtml  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model CustomerMemory {
  id                String    @id @default(cuid())
  workspaceId       String
  email             String    @unique
  name              String?
  relationshipScore Int       @default(0)
  knownSince        DateTime  @default(now())
  lastSummary       String?
  budget            String?
  painPoints        String?
  requirements      String?
  lastMeetingAt     DateTime?
  lifetimeValue     Float     @default(0.0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads             Lead[]
  emails            Email[]

  @@index([workspaceId])
  @@index([email])
}

model Conversation {
  id            String    @id @default(cuid())
  workspaceId   String
  customerEmail String
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  threads       Thread[]

  @@index([workspaceId])
  @@index([customerEmail])
}

model Thread {
  id             String        @id @default(cuid())
  workspaceId    String
  gmailThreadId  String        @unique
  conversationId String?
  snippet        String?
  subject        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  emails         Email[]

  @@index([workspaceId])
  @@index([gmailThreadId])
  @@index([conversationId])
}

model Attachment {
  id        String   @id @default(cuid())
  emailId   String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  // Relations
  email     Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
}

model CompanyKnowledge {
  id                       String         @id @default(cuid())
  workspaceId              String         @unique
  websiteUrl               String
  pagesIndexed             Int            @default(0)
  lastSyncAt               DateTime?
  knowledgeSize            Int            @default(0)
  autoSync                 Boolean        @default(true)
  enableLearning           Boolean        @default(true)
  enableConversationMemory Boolean        @default(true)
  status                   String         @default("IDLE")
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  // Relations
  workspace                Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages                    CrawledPage[]

  @@index([workspaceId])
}

model CrawledPage {
  id                 String           @id @default(cuid())
  companyKnowledgeId String
  url                String
  title              String?
  content            String?
  lastCrawledAt      DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  companyKnowledge   CompanyKnowledge @relation(fields: [companyKnowledgeId], references: [id], onDelete: Cascade)

  @@unique([companyKnowledgeId, url])
  @@index([companyKnowledgeId])
}
